# JWT 签名密钥，使用: openssl rand -hex 32
JWT_SECRET=

# 密码 bcrypt hash，使用: htpasswd -bnBC 12 "" yourpassword | tr -d ':\n'
# 或者: node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(h=>console.log(h))"
ACC_PASSWORD_HASH=

# 要 attach 的 tmux session 名
TMUX_SESSION=main

# 宿主机工作区根目录
WORKSPACE_ROOT=/workspace

# 服务监听端口
PORT=59000

# Claude 启动时注入的代理（用于访问 Anthropic API）
# 格式: http://host:port，留空则不注入代理
CLAUDE_PROXY=http://127.0.0.1:6789

# Telegram Bot Token（可选）
# 获取方式: @BotFather → /newbot → 复制 token
# 配置后可通过 Telegram 给 AI 下任务，结果自动回复
TELEGRAM_BOT_TOKEN=

# Telegram Webhook Secret（可选，用于验证 Telegram 来源）
# 使用: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=

# Telegram 默认使用的 tmux 窗口名（留空则使用第一个窗口）
TELEGRAM_DEFAULT_SESSION=
